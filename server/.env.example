# Pick one provider. Default is groq if unset.
LLM_PROVIDER=groq

# Required when LLM_PROVIDER=groq. Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# Required when LLM_PROVIDER=gemini. Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

PORT=3001
